{
  "name": "@humanbased-ai/verifyflow",
  "version": "0.1.0",
  "description": "Evidence-backed delivery verification agent: does a PR deliver its linked Linear issue?",
  "type": "module",
  "bin": {
    "verifyflow": "dist/cli/main.js",
    "vf": "dist/cli/main.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "fixtures",
    "architecture.md",
    "prd.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "tsc -p tsconfig.json",
    "vf": "tsx src/cli/main.ts",
    "test": "node --import tsx --test $(find src -name '*.test.ts' -print)",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "delivery-verification",
    "acceptance-criteria",
    "linear",
    "github",
    "pull-request",
    "playwright",
    "ai",
    "automation",
    "cli"
  ],
  "homepage": "https://github.com/humanbased-ai/verifyflow#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/humanbased-ai/verifyflow.git"
  },
  "bugs": {
    "url": "https://github.com/humanbased-ai/verifyflow/issues"
  },
  "author": "HumanBased AI",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  },
  "optionalDependencies": {
    "playwright": "^1.48.0"
  }
}
